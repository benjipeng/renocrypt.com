---
import Base from "../../layouts/Base.astro";
import {
  articleDescription,
  articlePath,
  articleTopics,
  formatDate,
  getPublishedArticles,
  readingTime,
  topicSlug,
} from "../../lib/content";

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  const map = new Map<
    string,
    { name: string; entries: typeof articles }
  >();
  for (const entry of articles) {
    for (const topic of articleTopics(entry)) {
      const slug = topicSlug(topic);
      if (!slug) continue;
      const bucket = map.get(slug) || { name: topic, entries: [] };
      bucket.entries.push(entry);
      map.set(slug, bucket);
    }
  }
  return [...map.entries()].map(([slug, { name, entries }]) => ({
    params: { topic: slug },
    props: { name, entries },
  }));
}

const { name, entries } = Astro.props;
// Humanize the slug for display/SEO (topics are stored lowercase-hyphenated),
// so the <title>, meta, and H1 all read "machine learning" rather than "machine-learning".
const label = name.replace(/-/g, " ");
---

<Base
  title={`${label} · Topics · RenoCrypt`}
  description={`RenoCrypt writing tagged ${label}.`}
>
  <section class="mx-auto max-w-6xl px-5 py-12 sm:px-8 lg:py-16">
    <header class="max-w-3xl">
      <a href="/topics/" class="eyebrow transition-colors hover:text-accent"
        >&rsaquo;&nbsp;&nbsp;topics</a
      >
      <h1 class="mt-5 font-display text-[2.2rem] leading-tight sm:text-5xl">
        {label}
      </h1>
      <p class="mt-5 font-mono text-sm uppercase tracking-[0.14em] text-muted">
        {entries.length} {entries.length === 1 ? "piece" : "pieces"}
      </p>
    </header>

    <div class="mt-10">
      {
        entries.map((entry) => (
          <a class="article-card" href={articlePath(entry)}>
            <div class="flex flex-wrap items-center gap-x-3 gap-y-1 font-mono text-[0.7rem] uppercase tracking-[0.14em] text-muted">
              <span>{formatDate(entry.data.date)}</span>
              <span>{readingTime(entry)} min read</span>
            </div>
            <h2 class="mt-3 max-w-3xl font-display text-2xl">
              {entry.data.title}
            </h2>
            <p class="mt-2 max-w-2xl leading-relaxed text-muted">
              {articleDescription(entry)}
            </p>
            <div class="mt-4 flex flex-wrap gap-2">
              {articleTopics(entry)
                .slice(0, 4)
                .map((t) => (
                  <span class="reno-chip">{t}</span>
                ))}
            </div>
          </a>
        ))
      }
    </div>
  </section>
</Base>
