---
/**
 * RenoCrypt mark: a 3x3 "matrix" that swells toward a single gold core, the
 * one element transmuted to gold. Pure dots, radially symmetric.
 *
 * Static by default. With `animated`, the accent travels by turning dots into
 * hollow emerald rings, the cross then the diagonals, then back. Each position
 * is ever a solid dot OR a hollow ring, never both, so it stays clean. The gold
 * core breathes. Colors are theme variables (day/night), motion yields to
 * reduced-motion.
 */
interface Props {
  size?: number;
  class?: string;
  title?: string;
  animated?: boolean;
  breathe?: boolean;
}
const {
  size = 28,
  class: cls = "",
  title,
  animated = false,
  breathe = false,
} = Astro.props;

const corners = [
  [12, 12],
  [36, 12],
  [12, 36],
  [36, 36],
];
const plus = [
  [24, 12],
  [12, 24],
  [36, 24],
  [24, 36],
];
---

<svg
  width={size}
  height={size}
  viewBox="0 0 48 48"
  class={`reno-mark ${animated ? "is-animated" : ""} ${breathe ? "is-breathing" : ""} ${cls}`}
  role={title ? "img" : "presentation"}
  aria-hidden={title ? undefined : "true"}
  xmlns="http://www.w3.org/2000/svg"
>
  {title && <title>{title}</title>}

  <g class="rm-orbit">
    {corners.map(([x, y]) => <circle cx={x} cy={y} r="2" fill="currentColor" opacity="0.85" class="rm-dot-c" />)}
    {plus.map(([x, y]) => <circle cx={x} cy={y} r="2.9" fill="currentColor" class="rm-dot-p" />)}
  </g>

  {animated && plus.map(([x, y]) => <circle cx={x} cy={y} r="3.2" fill="none" stroke="var(--accent)" stroke-width="1.6" class="rm-ring-p" />)}
  {animated && corners.map(([x, y]) => <circle cx={x} cy={y} r="2.7" fill="none" stroke="var(--accent)" stroke-width="1.5" class="rm-ring-c" />)}

  <circle cx="24" cy="24" r="4.3" fill="var(--gold)" class="rm-core" />
</svg>

<style>
  .rm-ring-p,
  .rm-ring-c {
    opacity: 0;
  }
  .rm-core {
    transform-box: fill-box;
    transform-origin: center;
  }
  /* Breathing variant: the matrix gently extends and retracts, the core beats.
     Used as the footer's "at work" status glyph. */
  .is-breathing .rm-orbit {
    transform-box: fill-box;
    transform-origin: center;
    animation: rmOrbitExtend 2.4s ease-in-out infinite;
  }
  .is-breathing .rm-core {
    animation: rmCoreBeat 2.4s ease-in-out infinite;
  }
  @keyframes rmOrbitExtend {
    0%, 100% { scale: 1; }
    50% { scale: 1.12; }
  }
  @keyframes rmCoreBeat {
    0%, 100% { opacity: 0.75; scale: 1; }
    50% { opacity: 1; scale: 1.1; }
  }
  /* cross phase: plus dots become rings; diagonal phase: corners become rings */
  .is-animated .rm-dot-p {
    animation: rmDotP 5.6s ease-in-out infinite;
  }
  .is-animated .rm-ring-p {
    animation: rmRingP 5.6s ease-in-out infinite;
  }
  .is-animated .rm-dot-c {
    animation: rmDotC 5.6s ease-in-out infinite;
  }
  .is-animated .rm-ring-c {
    animation: rmRingC 5.6s ease-in-out infinite;
  }
  .is-animated .rm-core {
    animation: rmBreathe 5.6s ease-in-out infinite;
  }
  @keyframes rmDotP {
    0%, 10% { opacity: 1; }
    18%, 38% { opacity: 0; }
    46%, 100% { opacity: 1; }
  }
  @keyframes rmRingP {
    0%, 10% { opacity: 0; }
    18%, 38% { opacity: 0.95; }
    46%, 100% { opacity: 0; }
  }
  @keyframes rmDotC {
    0%, 48% { opacity: 0.85; }
    56%, 84% { opacity: 0; }
    92%, 100% { opacity: 0.85; }
  }
  @keyframes rmRingC {
    0%, 48% { opacity: 0; }
    56%, 84% { opacity: 0.95; }
    92%, 100% { opacity: 0; }
  }
  @keyframes rmBreathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .rm-dot-p,
    .rm-dot-c,
    .rm-ring-p,
    .rm-ring-c,
    .rm-orbit,
    .rm-core {
      animation: none !important;
    }
  }
</style>
