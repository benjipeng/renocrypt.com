---
/**
 * ML/AI art: a gradient vector field descending toward a gold optimum.
 * The math of learning, rendered as flow. Theme-token colors, day/night aware.
 */
const W = 440;
const H = 380;
const ax = 296; // attractor (the optimum)
const ay = 150;
const cols = 12;
const rows = 10;
const pad = 28;
const maxD = Math.hypot(W, H);

type Vec = { x: number; y: number; ex: number; ey: number; op: number; delay: string };
const vectors: Vec[] = [];
for (let r = 0; r < rows; r++) {
  for (let c = 0; c < cols; c++) {
    const x = pad + (c * (W - 2 * pad)) / (cols - 1);
    const y = pad + (r * (H - 2 * pad)) / (rows - 1);
    const dx = ax - x;
    const dy = ay - y;
    const d = Math.hypot(dx, dy) || 1;
    const len = 9 + 7 * (1 - Math.min(d / maxD, 1));
    vectors.push({
      x,
      y,
      ex: x + (dx / d) * len,
      ey: y + (dy / d) * len,
      op: 0.12 + 0.6 * (1 - Math.min(d / 320, 1)),
      // phase each vector's pulse by its distance from the optimum, so the
      // field visibly ripples outward from the gold point instead of the
      // whole grid blinking together
      delay: ((d / maxD) * 2.6).toFixed(2),
    });
  }
}
// a gradient-descent zig-zag path toward the optimum
const descent = "M40 350 L96 300 L150 280 L196 236 L236 214 L266 184 L286 164";
---

<svg
  viewBox={`0 0 ${W} ${H}`}
  class="art-svg"
  role="img"
  aria-label="A gradient field descending toward an optimum"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <radialGradient id="gfGold" cx="50%" cy="50%" r="50%">
      <stop offset="0%" stop-color="var(--gold)" style="stop-opacity: var(--glow-gold)"></stop>
      <stop offset="100%" stop-color="var(--gold)" stop-opacity="0"></stop>
    </radialGradient>
  </defs>

  <g class="gf-field">
    {
      vectors.map((v) => (
        <line
          x1={v.x}
          y1={v.y}
          x2={v.ex}
          y2={v.ey}
          stroke="var(--accent)"
          stroke-width="1.4"
          stroke-linecap="round"
          class="gf-vec"
          style={`--op:${v.op.toFixed(3)};animation-delay:${v.delay}s`}
        />
      ))
    }
  </g>

  <!-- descent trail + travelling particle -->
  <path
    d={descent}
    fill="none"
    stroke="var(--accent)"
    stroke-width="1.4"
    stroke-dasharray="2 5"
    opacity="0.5"
    class="gf-trail"></path>
  <circle
    r="3.4"
    fill="var(--accent)"
    class="gf-particle"
    style={`offset-path: path('${descent}');`}
  ></circle>

  <!-- the optimum -->
  <circle cx={ax} cy={ay} r="26" fill="url(#gfGold)" class="gf-halo"></circle>
  <circle cx={ax} cy={ay} r="5.5" fill="var(--gold)"></circle>
</svg>

<style>
  /* each vector pulses relative to its OWN base opacity (--op, set from
     distance-to-optimum), staggered by animation-delay so the field ripples
     outward from the gold point instead of the whole grid blinking as one
     flat block */
  .gf-vec {
    animation-name: gfPulseVec;
    animation-duration: 4s;
    animation-timing-function: ease-in-out;
    animation-iteration-count: infinite;
  }
  .gf-trail {
    animation: gfTrailFlow 1.1s linear infinite;
  }
  .gf-halo {
    transform-box: fill-box;
    transform-origin: center;
    animation: gfPulse 4.5s ease-in-out infinite;
  }
  .gf-particle {
    filter: drop-shadow(0 0 4px var(--accent));
    offset-rotate: 0deg;
    animation: gfTravel 5.5s linear infinite;
  }
  @keyframes gfPulseVec {
    0%, 100% { opacity: calc(var(--op) * 0.55); }
    50% { opacity: var(--op); }
  }
  @keyframes gfTrailFlow {
    from { stroke-dashoffset: 0; }
    to { stroke-dashoffset: -7; }
  }
  @keyframes gfPulse {
    0%, 100% { opacity: 0.5; transform: scale(1); }
    50% { opacity: 0.95; transform: scale(1.12); }
  }
  @keyframes gfTravel {
    from { offset-distance: 0%; }
    to { offset-distance: 100%; }
  }
</style>
