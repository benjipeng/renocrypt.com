---
/**
 * Dev art: a signal lattice. Orthogonal traces with current pulsing through,
 * gold pads at the edges. Engineering rendered as a circuit. Theme tokens.
 *
 * Each trace's dash pattern is sized from its own exact path length (traces
 * are axis-aligned, so length is just the sum of H/V segment deltas) instead
 * of one shared magic number -- every trace shows the same two travelling
 * "current" blips regardless of how long or short it is, and the offset
 * animation always completes one exact lap (length -> 0), so the loop never
 * skips a beat.
 */
const traces = [
  { d: "M24 70 H150 V150 H270 V96 H416", len: 526 },
  { d: "M24 200 H92 V270 H214 V206 H300 V150 H416", len: 582 },
  { d: "M60 356 V262 H188 V312 H332 V356", len: 460 },
  { d: "M416 330 H308 V250 H360 V120", len: 370 },
  { d: "M150 24 V96 H236 V56 H416", len: 378 },
];
const durations = ["4.2s", "5.4s", "4.8s", "6s", "5s"];
const goldPads = [
  [416, 96],
  [416, 200],
  [416, 56],
  [416, 330],
];
const nodes = [
  [24, 70],
  [24, 200],
  [60, 356],
  [150, 24],
  [360, 120],
  [332, 356],
  [150, 150],
  [270, 150],
  [214, 270],
  [300, 206],
];
---

<svg
  viewBox="0 0 440 380"
  class="art-svg"
  role="img"
  aria-label="A circuit lattice with current pulsing through it"
  xmlns="http://www.w3.org/2000/svg"
>
  <defs>
    <filter id="slGlow" x="-120%" y="-120%" width="340%" height="340%">
      <feGaussianBlur stdDeviation="2.6"></feGaussianBlur>
    </filter>
  </defs>
  <!-- base traces -->
  {
    traces.map((t) => (
      <path
        d={t.d}
        fill="none"
        stroke="var(--trace)"
        stroke-width="1.4"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    ))
  }
  <!-- flowing current -->
  {
    traces.map((t, i) => {
      const dash = 10;
      const gap = t.len / 2 - dash;
      return (
        <path
          d={t.d}
          fill="none"
          stroke="var(--accent)"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="sl-current"
          style={`--len:${t.len};stroke-dasharray:${dash} ${gap};animation-duration:${durations[i]}`}
        />
      );
    })
  }

  {nodes.map(([x, y]) => <circle cx={x} cy={y} r="2.6" fill="var(--muted)" />)}
  {
    goldPads.map(([x, y]) => (
      <g class="sl-pad">
        <circle cx={x} cy={y} r="7.5" fill="var(--gold)" opacity="0.4" filter="url(#slGlow)" />
        <circle cx={x} cy={y} r="3.4" fill="var(--gold)" />
      </g>
    ))
  }
</svg>

<style>
  .sl-current {
    animation-name: slFlow;
    animation-timing-function: linear;
    animation-iteration-count: infinite;
    filter: drop-shadow(0 0 2.5px var(--accent));
  }
  .sl-pad {
    transform-box: fill-box;
    transform-origin: center;
    animation: slPad 3.6s ease-in-out infinite;
  }
  @keyframes slFlow {
    from { stroke-dashoffset: var(--len); }
    to { stroke-dashoffset: 0; }
  }
  @keyframes slPad {
    0%, 100% { opacity: 0.7; }
    50% { opacity: 1; }
  }
</style>
