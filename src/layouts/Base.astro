---
import "../styles/global.css";
import Logo from "../components/Logo.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = "RenoCrypt · Matrix Alchemy",
  description = "Matrix Alchemy. Writing on machine learning, AI, and engineering by RenoCrypt.",
  image = "/og.png",
  type = "website",
  publishedTime,
  modifiedTime,
  jsonLd,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(image, Astro.site).href;
const year = 2026;

const siteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "RenoCrypt",
  alternateName: "Matrix Alchemy",
  url: Astro.site?.href,
  description:
    "Matrix Alchemy. Writing on machine learning, AI, and engineering.",
};
const schemas = [
  siteSchema,
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];

const nav = [
  { label: "ML/AI", href: "/posts/" },
  { label: "Dev", href: "/dev/" },
  { label: "Topics", href: "/topics/" },
  { label: "About", href: "/about/" },
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#04060a" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="RenoCrypt" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    {
      type === "article" && publishedTime && (
        <meta property="article:published_time" content={publishedTime} />
      )
    }
    {
      type === "article" && modifiedTime && (
        <meta property="article:modified_time" content={modifiedTime} />
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RenoCrypt"
      href="/rss.xml"
    />
    <meta name="generator" content={Astro.generator} />
    {
      schemas.map((schema) => (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
      ))
    }

    <!-- Google Analytics (GA4) -->
    <script
      is:inline
      async
      src="https://www.googletagmanager.com/gtag/js?id=G-HD982YSB33"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-HD982YSB33");
    </script>

    <!-- Set theme before paint to avoid a flash. Dark is the default. -->
    <script is:inline>
      (() => {
        try {
          const q = new URLSearchParams(location.search).get("theme");
          const stored = localStorage.getItem("reno-theme");
          const theme =
            q === "light" || q === "dark"
              ? q
              : stored ||
                (window.matchMedia("(prefers-color-scheme: light)").matches
                  ? "light"
                  : "dark");
          document.documentElement.dataset.theme = theme;
          const m = document.querySelector('meta[name="theme-color"]');
          if (m) m.content = theme === "light" ? "#f2eee2" : "#04060a";
          if (
            window.matchMedia("(prefers-reduced-motion: no-preference)").matches
          ) {
            document.documentElement.classList.add("reveal-ready");
          }
        } catch (_) {
          document.documentElement.dataset.theme = "dark";
        }
      })();
    </script>
  </head>

  <body class="min-h-screen antialiased">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-panel focus:px-4 focus:py-2 focus:text-fg"
      >Skip to content</a
    >

    <header
      class="sticky top-0 z-40 border-b border-line bg-bg/70 backdrop-blur-md"
    >
      <div
        class="mx-auto flex h-16 max-w-6xl items-center justify-between px-5 sm:px-8"
      >
        <a
          href="/"
          class="group flex items-center gap-2.5 text-fg"
          aria-label="RenoCrypt home"
        >
          <Logo size={28} animated />
          <span
            class="reno-wm font-display text-[0.98rem]"
            style="font-weight:600"
            data-wordmark
            aria-label="RenoCrypt"
          >
            <span class="ch" aria-hidden="true">R</span><span class="rest" aria-hidden="true"><span class="ch">e</span><span class="ch">n</span><span class="ch">o</span><span class="ch em">C</span><span class="ch em">r</span><span class="ch em">y</span><span class="ch em">p</span><span class="ch em">t</span></span><span class="slash" aria-hidden="true">&#92;</span>
          </span>
        </a>

        <nav class="flex items-center gap-1 sm:gap-2">
          {
            nav.map((item) => (
              <a
                href={item.href}
                class="nav-link inline-flex min-h-11 items-center rounded-md px-3 font-mono text-[0.78rem] uppercase tracking-[0.14em] text-muted"
              >
                {item.label}
              </a>
            ))
          }
          <button
            id="theme-toggle"
            type="button"
            aria-label="Switch to light theme"
            aria-pressed="false"
            class="ml-1 grid size-11 place-items-center rounded-md border border-line text-muted transition-colors hover:text-fg sm:size-9"
          >
            <!-- moon (dark) -->
            <svg
              class="size-4 rotate-0 opacity-100 transition-[opacity,transform] duration-200 [grid-area:1/1] light:-rotate-90 light:opacity-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 12.8A9 9 0 1 1 11.2 3 7 7 0 0 0 21 12.8Z"></path></svg
            >
            <!-- sun (light) -->
            <svg
              class="size-4 rotate-90 opacity-0 transition-[opacity,transform] duration-200 [grid-area:1/1] light:rotate-0 light:opacity-100"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.6"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="4"></circle><path
                d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
              ></path></svg
            >
          </button>
        </nav>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="mt-24 border-t border-line">
      <div
        class="mx-auto flex max-w-6xl flex-col gap-6 px-5 py-12 sm:flex-row sm:items-center sm:justify-between sm:px-8"
      >
        <div class="flex items-center gap-2.5">
          <span
            class="font-display text-[0.95rem] text-fg"
            style="font-weight:600">RenoCrypt</span
          >
          <Logo size={24} breathe class="text-fg" />
          <span class="font-mono text-xs text-muted" aria-hidden="true"
            ><span data-status-word>Percolating</span><span class="ell"
              ><span>.</span><span>.</span><span>.</span></span
            ></span
          >
        </div>
        <div class="flex items-center gap-2.5 font-mono text-xs text-muted">
          <span class="eyebrow">Matrix Alchemy</span>
          <span aria-hidden="true" class="opacity-40">&middot;</span>
          <span>&copy; {year} RenoCrypt</span>
        </div>
      </div>
    </footer>

    <script is:inline>
      (() => {
        const btn = document.getElementById("theme-toggle");
        if (!btn) return;
        const meta = document.querySelector('meta[name="theme-color"]');
        const sync = (theme) => {
          const light = theme === "light";
          btn.setAttribute("aria-pressed", String(light));
          btn.setAttribute(
            "aria-label",
            light ? "Switch to dark theme" : "Switch to light theme"
          );
          if (meta) meta.content = light ? "#f2eee2" : "#04060a";
        };
        sync(document.documentElement.dataset.theme);
        btn.addEventListener("click", () => {
          const root = document.documentElement;
          const next = root.dataset.theme === "light" ? "dark" : "light";
          root.dataset.theme = next;
          sync(next);
          try {
            localStorage.setItem("reno-theme", next);
          } catch (_) {}
        });
      })();
    </script>

    <!-- Collapse the wordmark to R\ once the page is scrolled. -->
    <script is:inline>
      (() => {
        const wm = document.querySelector("[data-wordmark]");
        if (!wm) return;
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        let ticking = false;
        const update = () => {
          const y = window.scrollY || document.documentElement.scrollTop || 0;
          wm.classList.toggle("is-collapsed", y > 40);
          ticking = false;
        };
        window.addEventListener(
          "scroll",
          () => {
            if (!ticking) {
              requestAnimationFrame(update);
              ticking = true;
            }
          },
          { passive: true }
        );
        update();
      })();
    </script>

    <!-- Entrance reveal: fade-up [data-reveal] as it enters view. The hidden
         start state comes from .reveal-ready (added pre-paint only when motion
         is allowed), so no-JS / reduced-motion render everything with no FOUC. -->
    <script is:inline>
      (() => {
        if (!document.documentElement.classList.contains("reveal-ready")) return;
        const els = document.querySelectorAll("[data-reveal]");
        if (!els.length) return;
        if (!("IntersectionObserver" in window)) {
          els.forEach((el) => el.classList.add("is-in"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-in");
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.05 }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>

    <!-- Footer status: cycle an alchemical gerund, like a lab always at work. -->
    <script is:inline>
      (() => {
        const el = document.querySelector("[data-status-word]");
        if (!el) return;
        const words = [
          "Transmuting", "Distilling", "Brewing", "Fermenting", "Crystallizing",
          "Synthesizing", "Percolating", "Cultivating", "Incubating", "Composing",
          "Forging", "Tempering", "Crafting", "Concocting", "Cogitating",
          "Ruminating", "Musing", "Pondering", "Contemplating", "Deciphering",
          "Inferring", "Computing", "Crunching", "Tinkering", "Harmonizing",
          "Channeling", "Manifesting", "Germinating", "Sublimating", "Conjuring",
          "Metamorphosing", "Orchestrating", "Ideating",
        ];
        let i = Math.floor(Math.random() * words.length);
        el.textContent = words[i];
        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
        setInterval(() => {
          let n = i;
          while (n === i) n = Math.floor(Math.random() * words.length);
          i = n;
          el.style.opacity = "0";
          setTimeout(() => {
            el.textContent = words[i];
            el.style.opacity = "";
          }, 260);
        }, 3400);
      })();
    </script>
  </body>
</html>
